datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")   // 👈 keep it here
}

generator client {
  provider = "prisma-client-js"
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  invoices  Invoice[]
}

model Invoice {
  id         String   @id @default(uuid())
  customer   Customer @relation(fields: [customerId], references: [id])
  customerId String
  amount     Int
  status     String
  dueDate    DateTime
}

